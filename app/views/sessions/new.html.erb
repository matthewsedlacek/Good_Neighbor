
<%= form_with url: '/login', method: :post, local: true do |f| %>
    <%= f.label :username %>
    <%= f.text_field :username, name: :username %>

    <%= f.label :password %>
    <%= f.password_field :password, name: :password %>

    <%= collection_select :session, :o_r, ['owner', 'renter'], :to_s, :to_s %>

    <%= f.submit "log in" %>
<% end %><br>
Or <%= link_to 'Renter sign up', controller: 'renters', action: 'new' %> <br>
<%= link_to 'Owner sign up', controller: 'owners', action: 'new' %><br>
